# jikei_faq Environment Variables
# このファイルをコピーして `.env.local` を作成してください。
# `.env.local` は .gitignore 対象で commit されません。

# OpenAI API key（/api/generate で使用）
OPENAI_API_KEY=sk-...

# Google サービスアカウントのメール
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com

# Google サービスアカウントの秘密鍵（改行は \n のままで OK）
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# 書き込み対象スプレッドシートの ID（URL の /d/ と /edit の間）
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# 管理画面ログイン用シークレット
# 管理 API (knowledge / cases 全件・POST / setup / generate) の
# Authorization: Bearer <ADMIN_SECRET> 検証に使用する
ADMIN_SECRET=please-set-a-strong-random-value

