# ==========================================
# 慈恵医大 アクセシビリティAI相談システム
# 環境変数設定ファイル (.env)
# ==========================================
# ※ このファイルをコピーして `.env` にリネームし、
#    実際のキーを入力して使用してください。
# ※ GitHubなど公開リポジトリには絶対にコミットしないでください。
# ==========================================

# 1. サーバーのポート番号（デフォルト3000）
PORT=3000

# 2. Gemini APIキー
# 取得元: Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# 3. Google Spreadsheets 連携設定 (オプション)
# これらを入力しない場合は、スプレッドシート連携機能はスキップされ、ローカルのデモデータが使用されます

# スプレッドシートのID (URLの /d/ と /edit の間の文字列)
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# GCPサービスアカウントのメールアドレス
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account_email@your-project.iam.gserviceaccount.com

# GCPサービスアカウントの秘密鍵 (-----BEGIN PRIVATE KEY----- から始まるもの)
# 改行は \n のままでOKです
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
